# ⚠️  EXAMPLE — never commit real secrets. Create the real secret in each namespace.
#
# AGENT_INTERNAL_TOKEN is the shared cloud-agent token. It MUST be byte-identical
# to AGENT_INTERNAL_TOKEN in `tracker-api-secrets` (tracker-api validates what the
# agent sends). Generate once and put the SAME value in both secrets:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
#   kubectl create secret generic email-agent-secrets \
#     --from-literal=AGENT_INTERNAL_TOKEN='<same value as tracker-api-secrets>' \
#     --from-literal=LANGFUSE_PUBLIC_KEY='pk-lf-...' \
#     --from-literal=LANGFUSE_SECRET_KEY='sk-lf-...' \
#     --from-literal=SLACK_BOT_TOKEN='xoxb-...' \
#     -n jobradar-staging
#
# Per-user LLM keys and mailbox creds are NOT here — the agent fetches those at
# runtime from /agent/cloud/config/{user_id} (one user in memory at a time, H6).

apiVersion: v1
kind: Secret
metadata:
  name: email-agent-secrets
  namespace: jobradar
type: Opaque
stringData:
  AGENT_INTERNAL_TOKEN: "CHANGE_ME"   # must equal tracker-api-secrets/AGENT_INTERNAL_TOKEN
  LANGFUSE_PUBLIC_KEY: "CHANGE_ME"
  LANGFUSE_SECRET_KEY: "CHANGE_ME"
  SLACK_BOT_TOKEN: "CHANGE_ME"        # xoxb- bot token for ops alerts
