# ⚠️  This is an EXAMPLE. Never commit real secrets to git.
# Create the real secret with:
#
#   kubectl create secret generic tracker-api-secrets \
#     --from-literal=DATABASE_URL='postgresql://user:pass@host/db' \
#     --from-literal=SECRET_KEY='your-secret-key' \
#     -n jobradar
#
# Or use a secrets manager (e.g. AWS Secrets Manager + External Secrets Operator)

apiVersion: v1
kind: Secret
metadata:
  name: tracker-api-secrets
  namespace: jobradar
type: Opaque
stringData:
  DATABASE_URL: "postgresql://jobradar:CHANGE_ME@postgres-host:5432/jobradar"
  SECRET_KEY: "CHANGE_ME"
