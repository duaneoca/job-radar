# ⚠️  This is an EXAMPLE. Never commit real secrets to git.
#
# Generate keys:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#
# Create the real secret in both namespaces:
#   kubectl create secret generic tracker-api-secrets \
#     --from-literal=DATABASE_URL='postgresql://user:pass@host/db' \
#     --from-literal=SECRET_KEY='<64-hex-chars>'   \
#     --from-literal=ENCRYPTION_KEY='<Fernet key>' \
#     -n jobradar-production
#
# Key rotation (ENCRYPTION_KEY):
#   1. Set ENCRYPTION_KEY_OLD to the current ENCRYPTION_KEY value.
#   2. Set ENCRYPTION_KEY to the new Fernet key.
#   3. Deploy → app reads new rows with new key, old rows with old key.
#   4. Run: python scripts/reencrypt_keys.py --old-key "$OLD" --new-key "$NEW"
#   5. Remove ENCRYPTION_KEY_OLD from the secret and redeploy.

apiVersion: v1
kind: Secret
metadata:
  name: tracker-api-secrets
  namespace: jobradar
type: Opaque
stringData:
  DATABASE_URL: "postgresql://jobradar:CHANGE_ME@postgres-host:5432/jobradar"
  SECRET_KEY: "CHANGE_ME"          # JWT signing key — ≥32 random chars
  ENCRYPTION_KEY: "CHANGE_ME"      # Fernet key for stored API key encryption
  # ENCRYPTION_KEY_OLD: ""         # Set only during key rotation, then remove

  # ── Gmail OAuth (cloud mailbox users — JR-5) ──────────────────────────────
  # One shared Google "Web application" OAuth client (separate from the Desktop
  # client used by the local self-host path). Scope: gmail.modify.
  # REDIRECT_URI is per-environment and must match the Authorized redirect URI
  # configured on the OAuth client in Google Cloud Console:
  #   staging    → https://staging.job-radar.net/api/agent/oauth/callback
  #   production → https://job-radar.net/api/agent/oauth/callback
  # GOOGLE_OAUTH_CLIENT_ID: "CHANGE_ME.apps.googleusercontent.com"
  # GOOGLE_OAUTH_CLIENT_SECRET: "GOCSPX-CHANGE_ME"
  # GOOGLE_OAUTH_REDIRECT_URI: "https://job-radar.net/api/agent/oauth/callback"
