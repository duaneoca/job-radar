# Copy to .env (gitignored) and fill in. Source it before running the skill:
#   set -a; . ./.env; set +a
#
# Proton Bridge exposes local IMAP. Find the host/port and the Bridge-generated
# username/password in the Proton Bridge app (Settings → Mailbox / IMAP).
# The Bridge password is NOT your Proton account password.

JR_IMAP_HOST=127.0.0.1
JR_IMAP_PORT=1143
JR_IMAP_USER=you@proton.me
JR_IMAP_PASS=bridge-generated-password
JR_IMAP_FOLDER=Job Postings
JR_IMAP_SEC=starttls   # starttls (Proton Bridge) | ssl | plain
