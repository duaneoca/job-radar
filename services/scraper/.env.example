# Copy to .env and fill in values. Never commit .env to git.

REDIS_URL=redis://localhost:6379/0
TRACKER_API_URL=http://localhost:8000
ENVIRONMENT=development

# Adzuna API credentials — free tier, register at https://developer.adzuna.com/
# If unset, the Adzuna scraper is skipped and the other sources still run.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
